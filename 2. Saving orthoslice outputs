name = 'YOUR DATA'
path = 'YOUR PATH TO SAVE DATA'
def saveimage_col(data_object, path1,path2,path3,path4,slicen1,slicen2, slicen3): #defines your inputs
	ortho =  hx_project.create('HxOrthoSlice') #make the function ortho
	ortho.ports.data.connect(data_object)
	ortho.fire()
	ortho.ports.colormap.connect(hx_project.get('labels256.am'))#color of the slices
	ortho.fire()
	ortho.ports.sliceOrientation.selected=0 #view in the xy orientation
	ortho.fire()	
	ortho.ports.sliceNumber.value=slicen1 #slicenumber
	ortho.fire()
	snapshot = hx_project.create('HxSnapshotModule') #this makes the snapshot module
	snapshot.ports.input.connect(data_object)
	port_save=snapshot.ports.snapPath
	port_save.filenames=path1+path2 #defines the filepath and name for saving
	snapshot.fire()
	snapshot.ports.action.was_hit=True 
	snapshot.fire()

	ortho.ports.sliceOrientation.selected=1 #xz orientaion
	ortho.fire()	
	ortho.ports.sliceNumber.value=slicen2 #slicenumber
	ortho.fire()
	port_save.filenames=path1+path3
	snapshot.fire()
	snapshot.ports.action.was_hit=True 
	snapshot.fire()

	ortho.ports.sliceOrientation.selected=2 #yz orientation
	ortho.fire()	
	ortho.ports.sliceNumber.value=slicen3 #slicenumber
	ortho.fire()
	port_save.filenames=path1+path4
	snapshot.fire()
	snapshot.ports.action.was_hit=True 
	snapshot.fire()

